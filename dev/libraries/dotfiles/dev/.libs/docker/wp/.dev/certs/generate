#!/usr/bin/env bash
##
# Generates new keys/certificates.
#
# Last generated : 02-17-2022
# Expires on     : 03-19-2023
#
# Please consider carefully before running this again.
# The certificates generated by this script are already
# set as trusted by those working on Clever Canyon products.
##
# ---------------------------------------------------------------------------------------------------------------------
# $ ./dev/libraries/dotfiles/dev/.libs/docker/wp/.dev/certs/generate;
# ---------------------------------------------------------------------------------------------------------------------

cd "$(dirname "${BASH_SOURCE[0]}")" || exit 1;
. ../../../../../../../../utilities/load.bash; # Loads utilities.

# Configuration of SSL certs.
# A few variables for CLI args below.

days=395; # {@see https://o5p.me/Fz1NWM}.
output_dir=../../../../../../../../libraries/dotfiles/dev/.libs/docker/wp/certs;
if [[ ! -d "${output_dir}" ]]; then mkdir -p "${output_dir}"; fi;

key_usages=$(          tr -d '\n' <<-'ooo'
	digitalSignature,
	nonRepudiation,
	keyEncipherment,
	dataEncipherment,
	keyAgreement,
	keyCertSign,
	cRLSign
	ooo
);
extended_key_usages=$( tr -d '\n' <<-'ooo'
	serverAuth,
	clientAuth,
	codeSigning,
	emailProtection,
	anyExtendedKeyUsage
	ooo
);
subject=$(             tr -d '\n' <<-'ooo'
	/L=Johns Creek
	/ST=GA
	/C=US
	/O=Clever Canyon
	/OU=Engineering
	/CN=clevercanyon.com
	/emailAddress=admin@clevercanyon.com
	ooo
);
subject_alt_names=$(   tr -d '\n' <<-'ooo'
	IP:127.0.0.1,
	DNS:*.mac,
	DNS:*.dev,
	DNS:*.wp,
	DNS:*.dkr,
	DNS:*.vm,
	DNS:local,
	DNS:*.local,
	DNS:localhost,
	DNS:*.localhost,
	DNS:clevercanyon.com,
	DNS:*.clevercanyon.com
	ooo
);
# Root & intermediate CA keys.

openssl genrsa -out "${output_dir}"/root-ca-key.pem 4096;
openssl genrsa -out "${output_dir}"/i10e-ca-key.pem 4096;

# Root CA certificate.

openssl req -config ./openssl/config.cnf -extensions v3_ca \
	-new \
	-x509 \
	-nodes \
	-sha512 \
	-days "${days}" \
	-key "${output_dir}"/root-ca-key.pem \
	-out "${output_dir}"/root-ca-crt.pem \
	-subj "${subject}" -addext 'subjectAltName = '"${subject_alt_names}" \
	-addext 'keyUsage = '"${key_usages}" -addext 'extendedKeyUsage = '"${extended_key_usages}";

# Intermediate CSR & CA certificate.

openssl req -config ./openssl/config.cnf -extensions v3_i10e \
	-new \
	-nodes \
	-sha512 \
	-days "${days}" \
	-key "${output_dir}"/i10e-ca-key.pem \
	-out "${output_dir}"/i10e-ca-csr.pem \
	-subj "${subject}" -addext 'subjectAltName = '"${subject_alt_names}" \
	-addext 'keyUsage = '"${key_usages}" -addext 'extendedKeyUsage = '"${extended_key_usages}";

openssl ca -config ./openssl/config.cnf -extensions v3_ca \
	-notext \
	-batch \
	-md sha512 \
	-rand_serial \
	-days "${days}" \
	-cert "${output_dir}"/root-ca-crt.pem \
	-keyfile "${output_dir}"/root-ca-key.pem \
	-in "${output_dir}"/i10e-ca-csr.pem \
	-out "${output_dir}"/i10e-ca-crt.pem;

# Start clean each time.

rm -f ./openssl/*-db*;
rm -f ./openssl/certs/*;

touch ./openssl/certs/.keep; # Keep directory.
touch ./openssl/certs-db;    # Needs to exist anew.
