#!/usr/bin/env bash
##
# Tells macOS to trust these CAs; i.e., adds root & intermediate CAs to system keychain.
#
# Last generated : 02-17-2022
# Expires on     : 03-19-2023
#
# Please consider carefully before running this again.
# The certificates generated by this script are already
# set as trusted by those working on Clever Canyon products.
##
# ---------------------------------------------------------------------------------------------------------------------
# $ ./dev/libraries/dotfiles/dev/.libs/docker/wp/.dev/certs/update-keychain;
# ---------------------------------------------------------------------------------------------------------------------

cd "$(dirname "${BASH_SOURCE[0]}")" || false;
. ../../../../../../../../utilities/load.bash; # Loads utilities.

# Configuration of SSL certs.

output_dir=../../../../../../../../libraries/dotfiles/dev/.libs/docker/wp/certs;
sudo security -v add-trusted-cert -d -r trustRoot -k   /Library/Keychains/System.keychain "${output_dir}"/root-ca-crt.pem;
sudo security -v add-trusted-cert -d -r trustAsRoot -k /Library/Keychains/System.keychain "${output_dir}"/i10e-ca-crt.pem;
