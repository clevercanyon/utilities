{
	"license"           : "GPL-2.0-or-later",
	"name"              : "clevercanyon/utilities",
	"description"       : "Clever Canyon’s utilities for PHP/JS applications.",
	"authors"           : [
		{
			"name"     : "Clever Canyon",
			"homepage" : "https://clevercanyon.com",
			"role"     : "organization"
		}
	],
	"prefer-stable"     : true,
	"minimum-stability" : "dev",
	"config"            : {
		"platform"      : {
			"php" : "7.4.0"
		},
		"allow-plugins" : {
			"dealerdirect/phpcodesniffer-composer-installer" : true,
			"composer/package-versions-deprecated"           : true
		}
	},
	"require"           : {
		"php-64bit"         : "^7.4 || ^8.0 || ^8.1",
		"ext-mbstring"      : "*",
		"ext-json"          : "*",
		"league/commonmark" : "^2.2"
	},
	"suggest"           : {
		"ext-fileinfo"        : "*",
		"ext-intl"            : "*",
		"ext-memcached"       : "*",
		"ext-pcntl"           : "*",
		"ext-pdo"             : "*",
		"ext-posix"           : "*",
		"ext-readline"        : "*",
		"ext-session"         : "*",
		"ext-zip"             : "*",
		"ulrichsg/getopt-php" : "^4.0"
	},
	"autoload"          : {
		"psr-4" : {
			"Clever_Canyon\\Utilities\\" : [ "./src/classes" ]
		},
		"files" : [ "./src/functions/load.php" ]
	},
	"require-dev"       : {
		"clevercanyon/utilities-dev" : "dev-main"
	},
	"autoload-dev"      : {
		"psr-4" : {
			"Clever_Canyon\\Utilities\\Tests\\"          : [ "./tests/classes" ],
			"Clever_Canyon\\Utilities\\Dev\\Utilities\\" : [ "./dev/utilities/classes" ]
		}
	},
	"scripts"           : {
		"compile"          : "./dev/cli-tools/composer/compile",
		"post-install-cmd" : "[ $COMPOSER_DEV_MODE -eq 0 ] || ./dev/cli-tools/composer/on-post-install-cmd",
		"post-update-cmd"  : "[ $COMPOSER_DEV_MODE -eq 0 ] || ./dev/cli-tools/composer/on-post-update-cmd"
	},
	"extra"             : {
		"clevercanyon" : {
			"&" : {
				"brand"            : {
					"data" : {
						"n7m" : "c10n"
					},
					"aws"  : {
						"s3" : {
							"bucket"     : "clevercanyon",
							"cdn_domain" : "cdn.clevercanyon.com"
						}
					}
				},
				"project"          : {
					"data" : {
						"version"        : "1.0.0",
						"stable_tag"     : "1.0.0",

						"layout"         : "distro-lib",
						"namespace_crux" : "Clever_Canyon\\Utilities",
						"name"           : "Clever Canyon: PHP/JS Utilities"
					}
				},
				"php_scoper"       : {
					"cfg" : {
						"expose-namespaces"  : [ ],
						"expose-constants"   : [ ],
						"expose-classes"     : [ ],
						"expose-functions"   : [ ],

						"exclude-namespaces" : [ ],
						"exclude-constants"  : [ ],
						"exclude-classes"    : [ ],
						"exclude-functions"  : [ ],
						"exclude-files"      : [ ]
					}
				},
				"post_cmd_handler" : {
					"symlink_local_packages" : {
						"vendor"       : [
							"clevercanyon/standards",
							"clevercanyon/utilities",
							"clevercanyon/utilities-dev",
							"clevercanyon/utilities-dev-npm"
						],
						"node_modules" : [
							"@clevercanyon/utilities-dev-npm"
						]
					}
				}
			}
		}
	}
}
