{
	"license"           : "GPL-2.0-or-later",
	"name"              : "clevercanyon/php-js-utilities",
	"description"       : "Intended for internal company use only. CLEVER CANYON's utilities are for PHP/JS development.",
	"authors"           : [
		{
			"name"     : "CLEVER CANYON",
			"homepage" : "https://clevercanyon.com",
			"role"     : "organization"
		}
	],
	"prefer-stable"     : true,
	"minimum-stability" : "dev",
	"config"            : {
		"process-timeout"     : 0,
		"optimize-autoloader" : true,
		"allow-plugins"       : {
			"dealerdirect/phpcodesniffer-composer-installer" : true
		}
	},
	"require"           : {
		"php"                    : "^7.4 || ^8.0 || ^8.1",
		"ext-json"               : "*",
		"ext-mbstring"           : "*",
		"ext-zip"                : "*",

		"ulrichsg/getopt-php"    : "^4.0",
		"clevercanyon/php-chalk" : "dev-main"
	},
	"autoload"          : {
		"psr-4" : {
			"Clever_Canyon\\Utilities\\" : "./src/classes"
		}
	},
	"require-dev"       : {
		"clevercanyon/php-js-utilities-dev" : "dev-main"
	},
	"autoload-dev"      : {
		"psr-4" : {
			"Clever_Canyon\\Utilities__Tests\\" : "./tests/classes"
		}
	},
	"scripts"           : {
		"post-update-cmd"   : [
			"[ $COMPOSER_DEV_MODE -eq 0 ] || ./vendor/clevercanyon/php-js-utilities-dev/src/toolchain/composer/post-update-cmd.php"
		],
		"run-project-tests" : [
			"./vendor/bin/phpunit --configuration ./.phpunit.xml --testsuite tests"
		]
	},
	"extra"             : {
		"clevercanyon" : {
			"@extends-packages" : [ "clevercanyon/php-js-utilities-dev" ]
		}
	}
}
