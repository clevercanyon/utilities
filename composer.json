{
	"license"           : "GPL-2.0-or-later",
	"name"              : "clevercanyon/php-js-utilities",
	"description"       : "CLEVER CANYON’s utilities for PHP/JS applications.",
	"authors"           : [
		{
			"name"     : "CLEVER CANYON",
			"homepage" : "https://clevercanyon.com",
			"role"     : "organization"
		}
	],
	"prefer-stable"     : true,
	"minimum-stability" : "dev",
	"config"            : {
		"platform"      : {
			"php-64bit" : "7.4.0"
		},
		"allow-plugins" : {
			"dealerdirect/phpcodesniffer-composer-installer" : true,
			"composer/package-versions-deprecated"           : true
		}
	},
	"require"           : {
		"php-64bit"              : "^7.4 || ^8.0 || ^8.1",
		"ext-json"               : "*",
		"ext-mbstring"           : "*",

		"clevercanyon/php-chalk" : "dev-main"
	},
	"suggest"           : {
		"ext-zip"             : "*",
		"ulrichsg/getopt-php" : "^4.0"
	},
	"autoload"          : {
		"psr-4" : {
			"Clever_Canyon\\Utilities\\" : "./src/classes"
		}
	},
	"require-dev"       : {
		"clevercanyon/php-js-utilities-dev" : "dev-main"
	},
	"autoload-dev"      : {
		"psr-4" : {
			"Clever_Canyon\\Utilities__Tests\\" : "./tests/classes"
		}
	},
	"scripts"           : {
		"post-update-cmd"               : "[ $COMPOSER_DEV_MODE -eq 0 ] || ./dev/toolchain/composer/on-post-update-cmd",
		"phpunit"                       : "composer exec -- phpunit --configuration ./.phpunit.xml",
		"webpack"                       : "npx webpack --config ./.webpack.cjs",
		"php-scoper-config-file-update" : "./dev/toolchain/php-scoper/config-file update"
	},
	"extra"             : {
		"clevercanyon" : {
			"&" : {
				"project"                 : {
					"data" : {
						"version"    : "1.0.0",
						"stable_tag" : "1.0.0",
						"layout"     : "distro-lib",
						"name"       : "CLEVER CANYON: PHP/JS Utilities"
					}
				},
				"brand"                   : {
					"data" : {
						"name" : "CLEVER CANYON",
						"slug" : "clevercanyon"
					},
					"aws"  : {
						"s3" : {
							"bucket"     : "clevercanyon",
							"cdn_domain" : "cdn.clevercanyon.com"
						}
					}
				},
				"php_scoper"              : {
					"cfg" : {
						"exclude-constants" : [ ],
						"exclude-classes"   : [ ],
						"exclude-functions" : [ ]
					}
				},
				"post_update_cmd_handler" : {
					"symlink_local_packages" : {
						"vendor"       : [
							"clevercanyon/php-chalk",
							"clevercanyon/php-js-standards",
							"clevercanyon/php-js-utilities",
							"clevercanyon/php-js-utilities-dev",
							"clevercanyon/php-js-utilities-dev-npm"
						],
						"node_modules" : [
							"@clevercanyon/php-js-utilities-dev-npm"
						]
					}
				}
			}
		}
	}
}
